class Vehicle:
    def __init__(self, name, capacity):
        self.name = name
        self.capacity = capacity
    def fare(self):
        return self.capacity * 100
class Bus(Vehicle):
    def fare(self):
        amount = super().fare()
        total_fare = amount + (amount * 0.1)
        return total_fare
School_bus = Bus("School Volvo", 50)
print(f"Total {School_bus.name} fare is: {School_bus.fare()}")